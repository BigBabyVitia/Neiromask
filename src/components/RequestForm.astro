---
// Блок 3 — заявка / сбор инпутов. Единый вертикальный флоу (ширина как FAQ).
import RequestForm from './islands/RequestForm.tsx';
import { t } from '../copy';

const includes = [0, 1, 2, 3];
---

<section class="section" id="request">
  <div class="section-head">
    <span class="aj-chip">V</span>
    <h2 data-copy="rf.h2">{t('rf.h2')}</h2>
    <p data-copy="rf.lead">{t('rf.lead')}</p>
  </div>

  <div class="cta-flow">
    <RequestForm client:load />

    <div class="cta-includes">
      <strong data-copy="rf.includesTitle">{t('rf.includesTitle')}</strong>
      <ul>
        {
          includes.map((i) => (
            <li>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
              <span data-copy={`rf.includes.${i}`}>{t(`rf.includes.${i}`)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <style>
    /* Заголовок этого блока — в две строки */
    #request .section-head h2 {
      max-width: 600px;
      font-size: 30px;
      text-wrap: balance;
    }
  </style>
</section>
