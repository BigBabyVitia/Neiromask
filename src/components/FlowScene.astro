---
// Анимированные изометрические сцены-вайрфреймы для блока «Пять шагов».
// Одна сцена на шаг (1..5). Единый стиль: кремовая сцена, графитовые
// тонкие линии, синий бренд-акцент только на ключевом объекте, моно-
// подписи, пунктирный «пол». Анимация — CSS (см. global.css, блок «How
// scenes»), отключается в prefers-reduced-motion.
interface Props {
  step: number;
}
const { step } = Astro.props;

// --- изометрическая проекция (2:1 dimetric) -----------------------------
const OX = 170,
  OY = 64,
  TX = 19,
  TY = 9.5,
  TZ = 20;
const Pn = (x: number, y: number, z = 0): [number, number] => [
  +(OX + (x - y) * TX).toFixed(1),
  +(OY + (x + y) * TY - z * TZ).toFixed(1),
];
const P = (x: number, y: number, z = 0) => Pn(x, y, z).join(',');
const line = (a: number, b: number, c: number, d: number, e: number, f: number) =>
  [P(a, b, c), P(d, e, f)].join(' ');

// три видимые грани коробки: верх + две передние
const cube = (x: number, y: number, z: number, w: number, d: number, h: number) => ({
  top: [P(x, y, z + h), P(x + w, y, z + h), P(x + w, y + d, z + h), P(x, y + d, z + h)].join(' '),
  l: [P(x, y + d, z + h), P(x + w, y + d, z + h), P(x + w, y + d, z), P(x, y + d, z)].join(' '),
  r: [P(x + w, y, z + h), P(x + w, y + d, z + h), P(x + w, y + d, z), P(x + w, y, z)].join(' '),
});

// дельта между двумя iso-точками в px (для CSS-перемещений токенов)
const delta = (
  a: number, b: number, c: number,
  d: number, e: number, f: number
): string => {
  const [x1, y1] = Pn(a, b, c);
  const [x2, y2] = Pn(d, e, f);
  return `--tx:${+(x2 - x1).toFixed(1)}px;--ty:${+(y2 - y1).toFixed(1)}px`;
};

// общий пунктирный «пол» (крест) вокруг точки fx,fy
const Ground = (fx: number, fy: number, r = 3) => ({
  h: line(fx - r, fy, 0, fx + r, fy, 0),
  v: line(fx, fy - r, 0, fx, fy + r, 0),
});
const g1 = Ground(1.5, 1.5);
---

{
  /* ===================== ШАГ 1 — Вход / документ ===================== */
  step === 1 && (
    <svg class="flow-scene fs-1" viewBox="0 0 340 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="fs-art">
      {/* пол */}
      <polyline class="fs-floor" points={g1.h} />
      <polyline class="fs-floor" points={g1.v} />
      {/* призрачные входы (файл / тикет) позади */}
      <g class="fs-drift fs-d1">
        <polygon class="fs-face fs-dim" points={cube(2.4, -0.4, 1.0, 1.1, 0.8, 0.16).top} />
        <polygon class="fs-face fs-dim" points={cube(2.4, -0.4, 1.0, 1.1, 0.8, 0.16).l} />
        <polygon class="fs-face fs-dim" points={cube(2.4, -0.4, 1.0, 1.1, 0.8, 0.16).r} />
      </g>
      <g class="fs-drift fs-d2">
        <polygon class="fs-face fs-dim" points={cube(-0.9, 1.6, 0.7, 1.0, 0.8, 0.16).top} />
        <polygon class="fs-face fs-dim" points={cube(-0.9, 1.6, 0.7, 1.0, 0.8, 0.16).l} />
        <polygon class="fs-face fs-dim" points={cube(-0.9, 1.6, 0.7, 1.0, 0.8, 0.16).r} />
      </g>
      {/* платформа-приёмник */}
      <polygon class="fs-face fs-base" points={cube(0.2, 0.2, 0, 2.6, 2.6, 0.28).top} />
      <polygon class="fs-face fs-base" points={cube(0.2, 0.2, 0, 2.6, 2.6, 0.28).l} />
      <polygon class="fs-face fs-base" points={cube(0.2, 0.2, 0, 2.6, 2.6, 0.28).r} />
      {/* парящий документ */}
      <g class="fs-bob">
        <polygon class="fs-acc-face" points={cube(0.55, 0.55, 1.35, 1.9, 1.9, 0.14).top} />
        <polygon class="fs-face" points={cube(0.55, 0.55, 1.35, 1.9, 1.9, 0.14).l} />
        <polygon class="fs-face" points={cube(0.55, 0.55, 1.35, 1.9, 1.9, 0.14).r} />
        {/* строки текста на верхней грани */}
        <polyline class="fs-edge" points={line(0.85, 0.95, 1.49, 2.15, 0.95, 1.49)} />
        <polyline class="fs-edge fs-acc" points={line(0.85, 1.25, 1.49, 1.9, 1.25, 1.49)} />
        <polyline class="fs-edge" points={line(0.85, 1.55, 1.49, 2.0, 1.55, 1.49)} />
      </g>
      </g>
    </svg>
  )
}

{
  /* ===================== ШАГ 2 — Поиск сущностей (PII) ===================== */
  step === 2 && (
    <svg class="flow-scene fs-2" viewBox="0 0 340 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="fs-art">
      <polyline class="fs-floor" points={g1.h} />
      <polyline class="fs-floor" points={g1.v} />
      {/* лист документа на платформе */}
      <polygon class="fs-face fs-base" points={cube(0.4, 0.4, 0, 2.2, 2.2, 0.18).top} />
      <polygon class="fs-face fs-base" points={cube(0.4, 0.4, 0, 2.2, 2.2, 0.18).l} />
      <polygon class="fs-face fs-base" points={cube(0.4, 0.4, 0, 2.2, 2.2, 0.18).r} />
      {/* строки текста */}
      <polyline class="fs-edge" points={line(0.7, 0.75, 0.18, 2.55, 0.75, 0.18)} />
      <polyline class="fs-edge" points={line(0.7, 1.1, 0.18, 2.3, 1.1, 0.18)} />
      <polyline class="fs-edge" points={line(0.7, 1.45, 0.18, 2.55, 1.45, 0.18)} />
      <polyline class="fs-edge" points={line(0.7, 1.8, 0.18, 2.1, 1.8, 0.18)} />
      <polyline class="fs-edge" points={line(0.7, 2.15, 0.18, 2.4, 2.15, 0.18)} />
      {/* найденные PII-поля — подсвечиваются по очереди */}
      <g class="fs-pop fs-p1">
        <polygon class="fs-acc-face" points={cube(1.55, 0.6, 0.18, 0.95, 0.32, 0.001).top} />
      </g>
      <g class="fs-pop fs-p2">
        <polygon class="fs-acc-face" points={cube(0.6, 1.3, 0.18, 1.1, 0.32, 0.001).top} />
      </g>
      <g class="fs-pop fs-p3">
        <polygon class="fs-acc-face" points={cube(1.45, 1.65, 0.18, 0.95, 0.32, 0.001).top} />
      </g>
      {/* сканирующий луч */}
      <g class="fs-scan">
        <polyline class="fs-beam" points={line(0.4, 0.4, 0.18, 2.6, 0.4, 0.18)} />
        <polyline class="fs-beam" points={line(0.4, 0.4, 0.18, 0.4, 2.6, 0.18)} />
      </g>
      </g>
    </svg>
  )
}

{
  /* ===================== ШАГ 3 — Правило обработки (Политики) ===================== */
  step === 3 && (
    <svg class="flow-scene fs-3" viewBox="0 0 340 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="fs-art">
      <polyline class="fs-floor" points={Ground(1.25, 1.25, 2.6).h} />
      <polyline class="fs-floor" points={Ground(1.25, 1.25, 2.6).v} />
      {/* рельсы от узла к трём исходам */}
      <polyline class="fs-rail" points={line(1.25, 1.25, 1.55, -0.2, 1.9, 0.32)} />
      <polyline class="fs-rail" points={line(1.25, 1.25, 1.55, 1.25, 2.7, 0.32)} />
      <polyline class="fs-rail" points={line(1.25, 1.25, 1.55, 2.7, 1.9, 0.32)} />
      {/* узел-правило */}
      <polygon class="fs-acc-face" points={cube(0.95, 0.95, 1.55, 0.6, 0.6, 0.5).top} />
      <polygon class="fs-face fs-acc" points={cube(0.95, 0.95, 1.55, 0.6, 0.6, 0.5).l} />
      <polygon class="fs-face fs-acc" points={cube(0.95, 0.95, 1.55, 0.6, 0.6, 0.5).r} />
      {/* исход: mask (синий) */}
      <g class="fs-out fs-o1">
        <polygon class="fs-face fs-base" points={cube(-0.6, 1.4, 0.32, 0.9, 0.9, 0.22).top} />
        <polygon class="fs-face fs-base" points={cube(-0.6, 1.4, 0.32, 0.9, 0.9, 0.22).l} />
        <polygon class="fs-face fs-base" points={cube(-0.6, 1.4, 0.32, 0.9, 0.9, 0.22).r} />
        <circle class="fs-dot fs-dot-mask" cx={Pn(-0.15, 1.85, 0.54)[0]} cy={Pn(-0.15, 1.85, 0.54)[1]} r="3" />
      </g>
      {/* исход: block (warn) */}
      <g class="fs-out fs-o2">
        <polygon class="fs-face fs-base" points={cube(0.8, 2.3, 0.32, 0.9, 0.9, 0.22).top} />
        <polygon class="fs-face fs-base" points={cube(0.8, 2.3, 0.32, 0.9, 0.9, 0.22).l} />
        <polygon class="fs-face fs-base" points={cube(0.8, 2.3, 0.32, 0.9, 0.9, 0.22).r} />
        <circle class="fs-dot fs-dot-block" cx={Pn(1.25, 2.75, 0.54)[0]} cy={Pn(1.25, 2.75, 0.54)[1]} r="3" />
      </g>
      {/* исход: allow */}
      <g class="fs-out fs-o3">
        <polygon class="fs-face fs-base" points={cube(2.2, 1.4, 0.32, 0.9, 0.9, 0.22).top} />
        <polygon class="fs-face fs-base" points={cube(2.2, 1.4, 0.32, 0.9, 0.9, 0.22).l} />
        <polygon class="fs-face fs-base" points={cube(2.2, 1.4, 0.32, 0.9, 0.9, 0.22).r} />
        <circle class="fs-dot fs-dot-allow" cx={Pn(2.65, 1.85, 0.54)[0]} cy={Pn(2.65, 1.85, 0.54)[1]} r="3" />
      </g>
      {/* токены, бегущие по рельсам */}
      <circle class="fs-tok fs-tok1" cx={Pn(1.25, 1.25, 1.6)[0]} cy={Pn(1.25, 1.25, 1.6)[1]} r="3" style={`${delta(1.25, 1.25, 1.6, -0.15, 1.85, 0.55)}`} />
      <circle class="fs-tok fs-tok2" cx={Pn(1.25, 1.25, 1.6)[0]} cy={Pn(1.25, 1.25, 1.6)[1]} r="3" style={`${delta(1.25, 1.25, 1.6, 1.25, 2.75, 0.55)}`} />
      <circle class="fs-tok fs-tok3" cx={Pn(1.25, 1.25, 1.6)[0]} cy={Pn(1.25, 1.25, 1.6)[1]} r="3" style={`${delta(1.25, 1.25, 1.6, 2.65, 1.85, 0.55)}`} />
      </g>
    </svg>
  )
}

{
  /* ===================== ШАГ 4 — API-модель / Обезличивание ===================== */
  step === 4 && (
    <svg class="flow-scene fs-4" viewBox="0 0 340 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="fs-art">
      <polyline class="fs-floor" points={line(-0.6, 1.2, 0, 4.6, 1.2, 0)} />
      <polyline class="fs-floor" points={line(2.0, -0.6, 0, 2.0, 3.0, 0)} />
      {/* защищённый контур — слева */}
      <polygon class="fs-face fs-base" points={cube(0, 0.4, 0, 1.4, 1.4, 1.1).top} />
      <polygon class="fs-face fs-base" points={cube(0, 0.4, 0, 1.4, 1.4, 1.1).l} />
      <polygon class="fs-face fs-base" points={cube(0, 0.4, 0, 1.4, 1.4, 1.1).r} />
      {/* реальные данные «заперты» внутри */}
      <polyline class="fs-edge fs-acc" points={line(0.25, 0.65, 1.1, 1.15, 0.65, 1.1)} />
      <polyline class="fs-edge fs-acc" points={line(0.25, 1.0, 1.1, 0.95, 1.0, 1.1)} />
      <circle class="fs-lock" cx={Pn(1.05, 1.55, 1.1)[0]} cy={Pn(1.05, 1.55, 1.1)[1]} r="3.2" />
      {/* граница контура */}
      <polyline class="fs-bound" points={line(2.0, -0.4, 0, 2.0, -0.4, 1.7)} />
      <polyline class="fs-bound" points={line(2.0, 2.8, 0, 2.0, 2.8, 1.7)} />
      <polyline class="fs-bound" points={line(2.0, -0.4, 1.7, 2.0, 2.8, 1.7)} />
      {/* внешняя LLM — справа */}
      <g class="fs-llm">
        <polygon class="fs-acc-face" points={cube(3.0, 0.4, 0, 1.4, 1.4, 1.1).top} />
        <polygon class="fs-face fs-acc" points={cube(3.0, 0.4, 0, 1.4, 1.4, 1.1).l} />
        <polygon class="fs-face fs-acc" points={cube(3.0, 0.4, 0, 1.4, 1.4, 1.1).r} />
      </g>
      {/* обезличенный пакет, идущий наружу */}
      <g class="fs-packet" style={`${delta(1.0, 1.1, 1.25, 3.4, 1.1, 1.25)}`}>
        <polygon class="fs-acc-face" points={cube(0.7, 0.85, 1.25, 0.6, 0.5, 0.12).top} />
        <polygon class="fs-face fs-acc" points={cube(0.7, 0.85, 1.25, 0.6, 0.5, 0.12).l} />
        <polygon class="fs-face fs-acc" points={cube(0.7, 0.85, 1.25, 0.6, 0.5, 0.12).r} />
      </g>
      </g>
    </svg>
  )
}

{
  /* ===================== ШАГ 5 — Ответ и аудит (Нейроключ · Журнал) ===================== */
  step === 5 && (
    <svg class="flow-scene fs-5" viewBox="0 0 340 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <g class="fs-art">
      <polyline class="fs-floor" points={line(-0.4, 1.0, 0, 4.2, 1.0, 0)} />
      <polyline class="fs-floor" points={line(1.7, -0.8, 0, 1.7, 2.8, 0)} />
      {/* Нейроключ — узел восстановления */}
      <g class="fs-key">
        <polygon class="fs-acc-face" points={cube(1.2, 0.5, 0.9, 1.0, 1.0, 0.6).top} />
        <polygon class="fs-face fs-acc" points={cube(1.2, 0.5, 0.9, 1.0, 1.0, 0.6).l} />
        <polygon class="fs-face fs-acc" points={cube(1.2, 0.5, 0.9, 1.0, 1.0, 0.6).r} />
        {/* замочная скважина на верхней грани */}
        <circle class="fs-keyhole" cx={Pn(1.7, 1.0, 1.5)[0]} cy={Pn(1.7, 1.0, 1.5)[1]} r="3.4" />
      </g>
      {/* приходящий обезличенный ответ — справа, едет к ключу */}
      <g class="fs-resp" style={`${delta(3.3, 1.1, 1.45, 1.9, 1.1, 1.45)}`}>
        <polygon class="fs-acc-face" points={cube(3.0, 0.85, 1.45, 0.6, 0.5, 0.12).top} />
        <polygon class="fs-face fs-acc" points={cube(3.0, 0.85, 1.45, 0.6, 0.5, 0.12).l} />
        <polygon class="fs-face fs-acc" points={cube(3.0, 0.85, 1.45, 0.6, 0.5, 0.12).r} />
      </g>
      {/* журнал — стопка записей слева, появляются по очереди с галочкой */}
      <g class="fs-log fs-l1">
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0, 1.5, 0.55, 0.14).top} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0, 1.5, 0.55, 0.14).l} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0, 1.5, 0.55, 0.14).r} />
        <path class="fs-check" d={`M ${Pn(-0.45, 1.78, 0.15).join(' ')} l 2.4 2.4 l 4.6 -5.2`} />
      </g>
      <g class="fs-log fs-l2">
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.2, 1.5, 0.55, 0.14).top} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.2, 1.5, 0.55, 0.14).l} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.2, 1.5, 0.55, 0.14).r} />
        <path class="fs-check" d={`M ${Pn(-0.45, 1.78, 0.35).join(' ')} l 2.4 2.4 l 4.6 -5.2`} />
      </g>
      <g class="fs-log fs-l3">
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.4, 1.5, 0.55, 0.14).top} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.4, 1.5, 0.55, 0.14).l} />
        <polygon class="fs-face fs-base" points={cube(-0.7, 1.5, 0.4, 1.5, 0.55, 0.14).r} />
        <path class="fs-check" d={`M ${Pn(-0.45, 1.78, 0.55).join(' ')} l 2.4 2.4 l 4.6 -5.2`} />
      </g>
      </g>
    </svg>
  )
}
