---
import { t } from '../copy';
import TrustStrip from './TrustStrip.astro';

interface Props {
  /** Переопределить H1 (для версий блока). По умолчанию — copy.ts. */
  h1?: string;
  /** Переопределить лид. По умолчанию — copy.ts. */
  lead?: string;
  /** Шире контейнер H1 — чтобы длинная первая строка не переносилась. */
  wide?: boolean;
}
const { h1 = t('hero.h1'), lead = t('hero.lead'), wide = false } = Astro.props;
---

<section class="section pt-24 lg:pt-12 pb-0" id="top">
  <TrustStrip />

  <div
    class:list={[
      'hero-main mx-auto flex flex-col items-center text-center',
      wide ? 'max-w-[1080px]' : 'max-w-[860px]',
    ]}
  >
    <h1 class="hero-h1" data-copy="hero.h1" set:html={h1}></h1>

    <p
      class="mx-auto mt-6 max-w-[620px] text-[16px] text-muted"
      data-copy="hero.lead"
      set:html={lead}
    ></p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a class="btn btn--round" href="#request" data-copy="hero.cta">{t('hero.cta')}</a>
    </div>

    <div class="aj-legend justify-center" aria-label="Внутренняя разметка ценности">
      <span class="aj-legend-item"><span class="aj-key">B</span> большая работа</span>
      <span class="aj-legend-item"><span class="aj-key s">S</span> вспомогательная работа</span>
      <span class="aj-legend-item"><span class="aj-key v">V</span> ценность / outcome</span>
      <span class="aj-legend-item"><span class="aj-key p">P</span> proof / enablement</span>
      <span class="aj-legend-item"><span class="aj-key a">A</span> боль / тревога</span>
    </div>
  </div>
</section>
