---
// Site footer — mirrors the WMT sibling site (lichniy-ii): a dark closing band
// with the copyright line and legal links. One voice, shared across the project.
import { t } from '../copy';
---

<footer class="site-footer">
  <div class="site-footer__meta shell">
    <p class="site-footer__copy" data-copy="footer.copy">{t('footer.copy')}</p>
    <nav class="site-footer__links" aria-label="Документы">
      <a href="/privacy" data-copy="footer.privacy">{t('footer.privacy')}</a>
      <a href="/cookies" data-copy="footer.cookies">{t('footer.cookies')}</a>
    </nav>
  </div>

  <div class="site-footer__brand" data-footer-flicker aria-hidden="true">
    <canvas class="site-footer__flicker" data-footer-flicker-canvas data-text="НейроМаск"></canvas>
  </div>

  <style>
    .site-footer {
      /* Warm ink (same dark tone as the .btn fill) so the band stays on-brand
         with the paper palette instead of the sibling's cold #07080c. */
      position: relative;
      overflow: hidden;
      background: var(--color-ink);
      color: rgba(255, 255, 255, 0.55);
      min-height: clamp(350px, 34vw, 430px);
      padding: 46px 0 0;
    }
    .site-footer::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(70% 72% at 18% 0%, rgba(255, 241, 207, 0.14), transparent 58%),
        radial-gradient(64% 82% at 82% 12%, rgba(61, 107, 255, 0.16), transparent 60%);
      pointer-events: none;
    }
    .site-footer__brand {
      position: absolute;
      inset: 0;
      width: 100%;
      display: grid;
      place-items: center;
      overflow: hidden;
      isolation: isolate;
    }
    .site-footer__brand::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 3;
      background: linear-gradient(180deg, var(--color-ink) 0%, rgba(28, 24, 19, 0.98) 28%, transparent 48%, transparent 78%, var(--color-ink) 100%);
      pointer-events: none;
    }
    .site-footer__flicker {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 2;
      pointer-events: none;
      mix-blend-mode: screen;
      opacity: 0.95;
    }
    .site-footer__meta {
      position: relative;
      z-index: 4;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding-bottom: 24px;
    }
    .site-footer__copy {
      margin: 0;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.55);
    }
    .site-footer__links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }
    .site-footer__links a {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.55);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .site-footer__links a:hover,
    .site-footer__links a:focus-visible {
      color: #fff;
    }
    @media (max-width: 640px) {
      .site-footer {
        padding: 38px 0 0;
        min-height: 274px;
      }
      .site-footer__links {
        gap: 10px 18px;
      }
    }
  </style>

  <script>
    const roots = document.querySelectorAll<HTMLElement>('[data-footer-flicker]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const clamp = (value: number, min: number, max: number) => Math.max(min, Math.min(max, value));
    const smoothstep = (edge0: number, edge1: number, value: number) => {
      const x = clamp((value - edge0) / Math.max(0.0001, edge1 - edge0), 0, 1);
      return x * x * (3 - 2 * x);
    };

    roots.forEach((root) => {
      const canvas = root.querySelector<HTMLCanvasElement>('[data-footer-flicker-canvas]');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const text = canvas.dataset.text || 'НейроМаск';
      let frame = 0;
      let last = 0;
      let cols = 0;
      let rows = 0;
      let dpr = 1;
      let square = 3;
      let gap = 3;
      let maskCanvas = document.createElement('canvas');
      let maskCtx = maskCanvas.getContext('2d', { willReadFrequently: true });
      let opacities = new Float32Array(0);
      let textCells = new Uint8Array(0);

      const setup = () => {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        const width = Math.max(1, Math.round(root.clientWidth));
        const height = Math.max(1, Math.round(root.clientHeight));
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        maskCanvas.width = canvas.width;
        maskCanvas.height = canvas.height;
        square = width < 640 ? 3 : 4;
        gap = width < 640 ? 2 : 3;
        cols = Math.ceil(width / (square + gap));
        rows = Math.ceil(height / (square + gap));
        opacities = new Float32Array(cols * rows);
        textCells = new Uint8Array(cols * rows);
        for (let i = 0; i < opacities.length; i += 1) {
          opacities[i] = Math.random() * 0.22;
        }

        maskCtx = maskCanvas.getContext('2d', { willReadFrequently: true });
        if (!maskCtx) return;
        maskCtx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
        maskCtx.save();
        maskCtx.scale(dpr, dpr);
        let fontSize = clamp(width / 5.8, width < 640 ? 44 : 72, width < 640 ? 90 : 176);
        const maxTextWidth = width * 0.94;
        maskCtx.fillStyle = '#fff';
        maskCtx.font = `500 ${fontSize}px Lora, Georgia, serif`;
        for (let attempt = 0; attempt < 8; attempt += 1) {
          const measured = maskCtx.measureText(text).width;
          if (measured <= maxTextWidth || measured <= 0) break;
          fontSize *= maxTextWidth / measured;
          maskCtx.font = `500 ${fontSize}px Lora, Georgia, serif`;
        }
        maskCtx.textAlign = 'center';
        maskCtx.textBaseline = 'middle';
        maskCtx.fillText(text, width / 2, height * 0.68);
        maskCtx.restore();

        for (let col = 0; col < cols; col += 1) {
          for (let row = 0; row < rows; row += 1) {
            const x = col * (square + gap) * dpr;
            const y = row * (square + gap) * dpr;
            const size = square * dpr;
            const mask = maskCtx.getImageData(x, y, size, size).data;
            textCells[col * rows + row] = mask.some((value, i) => i % 4 === 3 && value > 18) ? 1 : 0;
          }
        }
      };

      const draw = (time = 0) => {
        const delta = Math.min(0.08, Math.max(0.016, (time - last) / 1000 || 0.016));
        last = time;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let col = 0; col < cols; col += 1) {
          for (let row = 0; row < rows; row += 1) {
            const index = col * rows + row;
            if (!reduce && Math.random() < 0.12 * delta) {
              opacities[index] = Math.random() * 0.22;
            }

            const x = col * (square + gap) * dpr;
            const y = row * (square + gap) * dpr;
            const size = square * dpr;
            const hasText = textCells[index] === 1;
            if (!hasText && opacities[index] < 0.12) continue;

            const yRatio = y / Math.max(1, canvas.height);
            const lowerTextBoost = hasText ? smoothstep(0.38, 0.92, yRatio) : 0;
            const base = hasText ? 0.1 + lowerTextBoost * 0.46 : 0.025;
            const opacity = Math.min(0.72, base + opacities[index] * (hasText ? 1.6 : 0.32));
            const warmCell = (col + row * 2) % 5 !== 0;
            ctx.fillStyle = warmCell
              ? `rgba(255, 241, 207, ${opacity.toFixed(3)})`
              : `rgba(92, 134, 255, ${(opacity * 0.72).toFixed(3)})`;
            ctx.fillRect(x, y, size, size);
          }
        }

        if (!reduce) frame = requestAnimationFrame(draw);
      };

      const resizeObserver = new ResizeObserver(() => {
        setup();
        draw(performance.now());
      });
      resizeObserver.observe(root);

      const intersectionObserver = new IntersectionObserver(([entry]) => {
        cancelAnimationFrame(frame);
        if (entry.isIntersecting && !reduce) {
          last = performance.now();
          frame = requestAnimationFrame(draw);
        } else {
          draw(performance.now());
        }
      });
      intersectionObserver.observe(canvas);

      setup();
      draw(performance.now());
    });
  </script>
</footer>
