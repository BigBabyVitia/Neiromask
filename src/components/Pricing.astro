---
// Блок 1 — прайсинг: две версии (облако / выделенный контур).
// Статичные карточки; CTA скроллят к блоку заявки (#request).
import { t } from '../copy';
import SilkBg from './SilkBg.astro';

const cloudFeats = [0, 1, 2, 3, 4];
const onpremFeats = [0, 1, 2, 3, 4];
---

<section class="section" id="pilot">
  <div class="section-head">
    <span class="eyebrow" data-copy="pr.eyebrow">{t('pr.eyebrow')}</span>
    <h2 data-copy="pr.h2">{t('pr.h2')}</h2>
    <p data-copy="pr.lead">{t('pr.lead')}</p>
  </div>

  <div class="pricing-grid">
    <!-- Облачная (рекомендуемая, silk-шейдер) -->
    <div class="plan-col">
      <div class="plan plan--aurora silk-grad silk-grad--deep">
        <SilkBg variant="deep" />
        <div class="plan-head">
          <span class="plan-name" data-copy="pr.cloudName">{t('pr.cloudName')}</span>
          <span class="plan-badge" data-copy="pr.cloudBadge">{t('pr.cloudBadge')}</span>
        </div>
        <p class="plan-tagline" data-copy="pr.cloudTagline">{t('pr.cloudTagline')}</p>

        <div class="plan-price"><b>от 45 000 ₽</b><span>/ мес</span></div>

        <ul class="plan-feats">
          {
            cloudFeats.map((i) => (
              <li>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
                <span data-copy={`pr.cloudFeats.${i}`}>{t(`pr.cloudFeats.${i}`)}</span>
              </li>
            ))
          }
        </ul>

        <div class="plan-foot">
          <a class="btn plan-cta" href="#request" data-copy="pr.cloudCta">{t('pr.cloudCta')}</a>
        </div>
      </div>
      <p class="plan-note plan-note--out" data-copy="pr.cloudNote">{t('pr.cloudNote')}</p>
    </div>

    <!-- Выделенный контур (on-prem) -->
    <div class="plan-col">
      <div class="plan">
        <div class="plan-head">
          <span class="plan-name" data-copy="pr.onpremName">{t('pr.onpremName')}</span>
          <span class="plan-badge plan-badge--soft">На сервере</span>
        </div>
        <p class="plan-tagline" data-copy="pr.onpremTagline">{t('pr.onpremTagline')}</p>

        <div class="plan-price"><b>По запросу</b></div>

        <ul class="plan-feats">
          {
            onpremFeats.map((i) => (
              <li>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
                <span data-copy={`pr.onpremFeats.${i}`}>{t(`pr.onpremFeats.${i}`)}</span>
              </li>
            ))
          }
        </ul>

        <div class="plan-foot">
          <a class="btn btn--secondary plan-cta" href="#request" data-copy="pr.onpremCta">{t('pr.onpremCta')}</a>
        </div>
      </div>
      <p class="plan-note plan-note--out" data-copy="pr.onpremNote">{t('pr.onpremNote')}</p>
    </div>
  </div>
</section>
