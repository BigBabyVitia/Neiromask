---
// Блок 1 — прайсинг: две версии (облако / выделенный контур).
// Статичные карточки; CTA скроллят к блоку заявки (#request).
const cloudFeats = [
  'Маскирование ФИО, телефонов, паспортов и реквизитов',
  'Карта правил mask / block / allow под ваш сценарий',
  'Восстановление ответа в контуре Нейроключа',
  'Журнал обработки для ИБ',
  'Интеграция с внешними LLM по API',
];
const onpremFeats = [
  'Установка в вашем закрытом контуре / on-prem',
  'Данные и карта восстановления не покидают периметр',
  'Интеграция с вашими моделями и SSO',
  'Требования к инфраструктуре под нагрузку',
  'Поддержка и обновления по SLA',
];
---

<section class="section" id="pilot">
  <div class="section-head">
    <span class="eyebrow">Тарифы</span>
    <h2>Облако или контур у вас</h2>
    <p>
      Две версии НейроМаск под нужный уровень контроля: быстрый старт в защищённом облаке или
      установка в вашем периметре. Разбор первого сценария — в любом формате.
    </p>
  </div>

  <div class="pricing-grid">
    <!-- Облачная (рекомендуемая, aurora) -->
    <div class="plan plan--aurora aurora-grad">
      <div class="plan-head">
        <span class="plan-name">Облачная</span>
        <span class="plan-badge">Быстрый старт</span>
      </div>
      <p class="plan-tagline">Запуск без установки — НейроМаск работает в защищённом облаке.</p>

      <div class="plan-price"><b>от 45 000 ₽</b><span>/ мес</span></div>
      <p class="plan-note">
        Лимиты по запросам, пользователям и объёму маскирования уточняются под сценарий.
      </p>

      <ul class="plan-feats">
        {
          cloudFeats.map((f) => (
            <li>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
              <span>{f}</span>
            </li>
          ))
        }
      </ul>

      <div class="plan-foot">
        <a class="btn plan-cta" href="#request">Разобрать сценарий</a>
      </div>
    </div>

    <!-- Выделенный контур (on-prem) -->
    <div class="plan">
      <div class="plan-head">
        <span class="plan-name">Выделенный контур</span>
        <span class="plan-badge plan-badge--soft">On-prem</span>
      </div>
      <p class="plan-tagline">Ставим НейроМаск на ваш сервер — данные не покидают периметр.</p>

      <div class="plan-price"><b>По запросу</b></div>
      <p class="plan-note">
        Стоимость зависит от инфраструктуры и объёма — рассчитываем индивидуально.
      </p>

      <ul class="plan-feats">
        {
          onpremFeats.map((f) => (
            <li>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
              <span>{f}</span>
            </li>
          ))
        }
      </ul>

      <div class="plan-foot">
        <a class="btn btn--secondary plan-cta" href="#request">Обсудить контур</a>
      </div>
    </div>
  </div>
</section>
