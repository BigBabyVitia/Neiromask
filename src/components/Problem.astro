---
import { t } from '../copy';

const risks = [0, 1, 2];
---

<section class="band aj-big" id="problem">
  <div class="section intro">
    <div class="intro-head">
      <span class="aj-chip">B</span>
      <h2 data-copy="problem.h2">{t('problem.h2')}</h2>
      <p class="lead mt-5 max-w-[760px] mx-auto" data-copy="problem.lead">
        <span data-copy="problem.lead.0">{t('problem.lead.0')}</span><strong data-copy="problem.lead.risk">{t('problem.lead.risk')}</strong><span data-copy="problem.lead.1">{t('problem.lead.1')}</span><strong data-copy="problem.lead.approval">{t('problem.lead.approval')}</strong><span data-copy="problem.lead.2">{t('problem.lead.2')}</span>
      </p>
      <div class="aj-note">
        <span class="aj-key">B</span>
        <span><strong>Большая работа:</strong> дать сотрудникам AI-инструмент и не превратить каждый документ в риск утечки.</span>
      </div>
    </div>

    <div class="risk-row">
      {
        risks.map((i) => (
          <div class="risk-box">
            <strong data-copy={`problem.risks.${i}.title`} style="white-space: pre-line">{t(`problem.risks.${i}.title`)}</strong>
            <p data-copy={`problem.risks.${i}.text`}>{t(`problem.risks.${i}.text`)}</p>
          </div>
        ))
      }
    </div>

  </div>
</section>
