---
const risks = [
  {
    n: 1,
    label: 'Потребность уже есть',
    title: 'Сотрудники используют LLM в рабочих задачах',
    text: 'Запрет не убирает пользу нейросетей. Он часто уводит работу в личные инструменты и серую зону.',
  },
  {
    n: 2,
    label: 'Данные без обработки',
    title: 'Персональные данные и реквизиты попадают в запрос',
    text: 'Тикеты, сканы, договоры и выгрузки содержат чувствительные фрагменты почти на каждой странице.',
  },
  {
    n: 3,
    label: 'Ручная чистка',
    title: 'Обезличивание руками не масштабируется',
    text: 'Чем больше документов и сканов, тем дороже проверять каждый фрагмент до работы с AI.',
  },
];

const needs = [
  'Нужны правила: что можно отправить, что замаскировать, что заблокировать.',
  'Нужен журнал: кто отправлял, какие сущности найдены, какое действие применено.',
  'Нужен результат: LLM должна сохранить смысл задачи после маскирования.',
];
---

<section class="band aj-big" id="problem">
  <div class="section intro">
    <div class="intro-head">
      <span class="aj-chip">B</span>
      <h2><span class="aj-mark aj-mark-anxiety" data-aj="A">Утечка персональных данных во внешние LLM</span> — ответственность компании.</h2>
      <p class="lead mt-5 max-w-[760px] mx-auto">
        Бизнесу нужны нейросети для документов и обращений, но отправка реальных ФИО, телефонов,
        паспортов и договоров во внешнюю модель создаёт риск по 152-ФЗ.
      </p>
      <div class="aj-note">
        <span class="aj-key">B</span>
        <span><strong>Большая работа:</strong> дать сотрудникам AI-инструмент и не превратить каждый документ в риск утечки.</span>
      </div>
    </div>

    <div class="risk-row">
      {
        risks.map((r) => (
          <div class="risk-box">
            <strong>{r.title}</strong>
            <p>{r.text}</p>
          </div>
        ))
      }
    </div>

    <ul class="bullets">
      {
        needs.map((n) => (
          <li>
            <span class="dot" />
            <span>{n}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
