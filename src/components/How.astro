---
import FlowScene from './FlowScene.astro';

const steps = [
  {
    n: 1,
    title: 'Запрос или документ',
    text: 'Пользователь, агент или внутренний сервис отправляет файл, скан, тикет или текст задачи.',
    tag: 'Вход',
  },
  {
    n: 2,
    title: 'Поиск сущностей',
    text: 'НейроМаск находит ФИО, телефоны, email, паспорта, реквизиты, номера договоров и другие чувствительные поля.',
    tag: 'Детектор PII',
  },
  {
    n: 3,
    title: 'Правило обработки',
    text: 'Для каждого сценария применяется действие: замаскировать, заблокировать или разрешить отправку.',
    tag: 'Политики',
  },
  {
    n: 4,
    title: 'API-модель',
    text: 'Во внешнюю LLM уходит обезличенный запрос с плейсхолдерами вместо реальных персональных данных.',
    tag: 'Обезличивание',
  },
  {
    n: 5,
    title: 'Ответ и аудит',
    text: 'Ответ возвращается в Нейроключ, данные восстанавливаются, событие остаётся в журнале.',
    tag: 'Нейроключ · Журнал',
  },
];
---

<section class="band" id="how">
  <div class="section aj-big">
    <div class="section-head">
      <span class="aj-chip">B</span>
      <h2>Пять шагов от чувствительного документа до безопасного ответа</h2>
      <p>
        Маршрут должен быть понятнее интерфейса: сначала правила и маскирование, затем внешняя
        API-модель, потом восстановленный ответ внутри Нейроключа.
      </p>
    </div>

    <div class="flow-stack">
      {/* central rail + the square that darts with scroll velocity */}
      <div class="flow-rail" aria-hidden="true">
        <span class="flow-meter"></span>
      </div>

      {
        steps.map((s, i) => (
          <article class={`flow-card flow-card--${i % 2 === 0 ? 'left' : 'right'}`}>
            <header class="flow-card__head">
              <span class="flow-card__num">{String(s.n).padStart(2, '0')}</span>
              <h3 class="flow-card__title">{s.title}</h3>
            </header>

            <div class="flow-card__stage" data-step={s.n}>
              <FlowScene step={s.n} />
            </div>

            <footer class="flow-card__foot">
              <span class="flow-card__icon" aria-hidden="true" />
              <span class="flow-card__tag">{s.tag}</span>
              <p class="flow-card__text">{s.text}</p>
            </footer>
          </article>
        ))
      }
    </div>

    <div class="aj-note">
      <span class="aj-key">B</span>
      <span><strong>Большая работа:</strong> сделать AI-сценарий управляемым, а не заставлять сотрудников чистить данные руками.</span>
    </div>
  </div>
</section>

<script>
  // Scroll-velocity meter: the square offsets from rail-center by how fast
  // you scroll, then springs back to center when the scroll settles.
  const meter = document.querySelector<HTMLElement>('.flow-meter');
  if (meter && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let pos = 0; // rendered offset (px)
    let target = 0; // velocity-driven target offset (px)
    let lastY = window.scrollY;

    window.addEventListener(
      'scroll',
      () => {
        const dy = window.scrollY - lastY;
        lastY = window.scrollY;
        // accumulate scroll delta, clamp travel to ±150px
        target = Math.max(-150, Math.min(150, target + dy * 0.6));
      },
      { passive: true }
    );

    const tick = () => {
      pos += (target - pos) * 0.2; // ease toward target
      target *= 0.9; // decay target back to center
      meter.style.transform = `translate(-50%, calc(-50% + ${pos.toFixed(2)}px))`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
