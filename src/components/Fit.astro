---
const fits = [
  'документы, сканы, PDF, DOCX и архивы файлов;',
  'договоры, акты, претензии, клиентские обращения;',
  'тикеты поддержки, CRM-выгрузки, базы знаний;',
  'HR, финансы и операционные документы как вторичные сценарии.',
];

const notFits = [
  'не плагин для личного ChatGPT или Codex;',
  'не универсальная гарантия комплаенса для любых данных;',
  'не замена DLP и юридической проверки;',
  'не основной продукт для программирования или работы с кодом.',
];
---

<section class="section aj-small" id="fit">
  <div class="section-head">
    <span class="aj-chip">S</span>
    <h2>Где НейроМаск работает лучше всего</h2>
    <p>
      Продукт нужен там, где AI уже полезен, но рабочие материалы содержат персональные данные, реквизиты,
      договорные условия или внутренние идентификаторы.
    </p>
  </div>

  <div class="fit-grid">
    <article class="fit-card">
      <h3>Подходит</h3>
      <ul>
        {fits.map((f) => <li>{f}</li>)}
      </ul>
    </article>
    <article class="fit-card no">
      <h3>Не позиционируем так</h3>
      <ul>
        {notFits.map((f) => <li>{f}</li>)}
      </ul>
    </article>
  </div>

  <div class="aj-note">
    <span class="aj-key s">S</span>
    <span><strong>Ограничение обещания:</strong> основной сценарий — API-модели и корпоративный контур, а не личные аккаунты сотрудников.</span>
  </div>
</section>
