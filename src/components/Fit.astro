---
import { t } from '../copy';

const fits = [0, 1, 2, 3];
---

<section class="section aj-small" id="fit">
  <div class="section-head">
    <span class="aj-chip">S</span>
    <h2 data-copy="fit.h2">{t('fit.h2')}</h2>
    <p data-copy="fit.lead">{t('fit.lead')}</p>
  </div>

  <div class="fit-grid fit-grid--single">
    <article class="fit-card">
      <h3 data-copy="fit.fitsTitle">{t('fit.fitsTitle')}</h3>
      <ul class="fit-cols">
        {fits.map((i) => <li data-copy={`fit.fits.${i}`}>{t(`fit.fits.${i}`)}</li>)}
      </ul>
    </article>
  </div>

  <div class="aj-note">
    <span class="aj-key s">S</span>
    <span><strong>Ограничение обещания:</strong> основной сценарий — API-модели и корпоративный контур, а не личные аккаунты сотрудников.</span>
  </div>

  <style>
    /* Один позитивный столбец «подходит» — границы продукта вынесены в Objections. */
    .fit-grid--single {
      grid-template-columns: 1fr;
      max-width: 760px;
      margin-inline: auto;
    }
    .fit-grid--single .fit-cols {
      columns: 2;
      column-gap: 28px;
    }
    .fit-grid--single .fit-cols li {
      break-inside: avoid;
      margin-bottom: 6px;
    }
    @media (max-width: 560px) {
      .fit-grid--single .fit-cols {
        columns: 1;
      }
    }
  </style>
</section>
