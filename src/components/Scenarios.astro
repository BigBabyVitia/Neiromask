---
import { t } from '../copy';

const scenarios = [
  {
    title: 'Документы и сканы',
    chip: 'B',
    accent: 'aj-big',
    variant: 'feature',
    now: 'Файлы содержат ФИО, паспорта, реквизиты и номера договоров.',
    mask: 'Персональные данные маскируются до API-модели, а результат остаётся полезным.',
  },
  {
    title: 'Договоры и юридические тексты',
    chip: 'B',
    accent: 'aj-big',
    variant: 'wide',
    now: 'Юристы не могут отправлять исходный текст договора во внешнюю LLM.',
    mask: 'Контрагенты, суммы и реквизиты скрываются до отправки.',
  },
  {
    title: 'Клиентская поддержка',
    chip: 'S',
    accent: 'aj-small',
    variant: 'standard',
    now: 'Тикеты содержат персональные данные, историю обращений и внутренние комментарии.',
    mask: 'AI используется через официальный канал с журналом и маскированием.',
  },
  {
    title: 'Финансы и операции',
    chip: 'S',
    accent: 'aj-small',
    variant: 'standard',
    now: 'Отчёты и выгрузки содержат суммы, контрагентов и внутренние условия.',
    mask: 'Чувствительные поля заменяются, сценарий можно открыть первым.',
  },
  {
    title: 'HR и рекрутинг',
    chip: 'P',
    accent: 'aj-proof',
    variant: 'soft',
    paragraph:
      'Вторичный сценарий: резюме, интервью и анкеты можно использовать как demo case, но не как главный сегмент НейроМаск.',
    note: 'понятный demo case, но не главный сегмент',
  },
];

const keyClass = (k: string) => (k === 'B' ? 'aj-key' : `aj-key ${k.toLowerCase()}`);
---

<section class="band" id="usecases">
  <div class="bento-wrap">
    <div class="section-head">
      <h2 data-copy="sc.h2">{t('sc.h2')}</h2>
      <p data-copy="sc.lead">{t('sc.lead')}</p>
    </div>

    <div class="bento-switch" role="tablist" aria-label="Состояние сценария">
      <button class="bento-switch__btn is-active" type="button" data-mode="now" aria-selected="true" data-copy="sc.switchNow">
        {t('sc.switchNow')}
      </button>
      <button class="bento-switch__btn" type="button" data-mode="mask" aria-selected="false" data-copy="sc.switchMask">
        {t('sc.switchMask')}
      </button>
    </div>

    <div class="bento" data-mode="now">
      {
        scenarios.map((s, i) => (
          <article class={`bento-card bento-card--${s.variant} ${s.accent}`}>
            <span class="aj-chip">{s.chip}</span>
            <h3 data-copy={`sc.items.${i}.title`}>{t(`sc.items.${i}.title`)}</h3>

            {s.now && <p class="bento-state" data-when="now" data-copy={`sc.items.${i}.now`}>{t(`sc.items.${i}.now`)}</p>}
            {s.mask && <p class="bento-state" data-when="mask" data-copy={`sc.items.${i}.mask`}>{t(`sc.items.${i}.mask`)}</p>}

            {s.paragraph && <p class="bento-card__lead" data-copy={`sc.items.${i}.paragraph`}>{t(`sc.items.${i}.paragraph`)}</p>}

            {s.note && (
              <div class="aj-note">
                <span class={keyClass(s.chip)}>{s.chip}</span>
                <span>{s.note}</span>
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.bento-switch').forEach((sw) => {
    const bento = sw.parentElement?.querySelector<HTMLElement>('.bento');
    if (!bento) return;
    sw.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.bento-switch__btn');
      if (!btn) return;
      sw.querySelectorAll<HTMLElement>('.bento-switch__btn').forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', String(on));
      });
      bento.dataset.mode = btn.dataset.mode || 'now';
    });
  });
</script>
