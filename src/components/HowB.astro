---
/* Версия «B» блока «Как работает» — короткий горизонтальный таймлайн.
   Тонкая линия с точками; синяя точка проходит по этапам, а пройденный
   участок линии заполняется синим (авто-цикл). Тот же текст из copy.ts,
   что и в How.astro. Без 3D-сцен и скролл-рейла. */
import { t } from '../copy';

const steps = [0, 1, 2, 3, 4];
---

<section class="band" id="how">
  <div class="section aj-big">
    <div class="howb-top">
      <div class="howb-head">
        <span class="aj-chip">B</span>
        <h2 data-copy="how.h2">{t('how.h2')}</h2>
        <p class="howb-lead" data-copy="how.lead">{t('how.lead')}</p>
      </div>
      <a class="btn btn--round howb-cta" href="#request" data-copy="hero.cta">{t('hero.cta')}</a>
    </div>

    <div class="howb-timeline">
      <div class="howb-track">
        <span class="howb-line" aria-hidden="true"></span>
        <span class="howb-line-fill" aria-hidden="true"></span>
        <ol class="howb-cols">
          {
            steps.map((i) => (
              <li class="howb-col">
                <span class="howb-dot" aria-hidden="true" />
                <h3 class="howb-col__title" data-copy={`how.steps.${i}.title`}>{t(`how.steps.${i}.title`)}</h3>
                <p class="howb-col__text" data-copy={`how.steps.${i}.text`}>{t(`how.steps.${i}.text`)}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .howb-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
  }
  .howb-head {
    max-width: 760px;
  }
  .howb-lead {
    margin-top: 12px;
    color: var(--color-muted);
  }
  .howb-cta {
    flex: none;
    margin-bottom: 4px;
  }
  @media (max-width: 720px) {
    .howb-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 22px;
    }
  }

  .howb-timeline {
    margin-top: 48px;
  }
  .howb-track {
    position: relative;
  }
  .howb-line {
    position: absolute;
    top: 6px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-line);
  }
  .howb-line-fill {
    position: absolute;
    top: 5px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-brand);
    /* transition управляется из JS (linear-проезд участка / fade сброса) */
    pointer-events: none;
  }
  .howb-cols {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 28px;
  }
  .howb-col {
    position: relative;
    padding-top: 32px;
  }
  .howb-dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 13px;
    height: 13px;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1.5px solid var(--color-line);
    transition: background 0.7s ease, border-color 0.7s ease, box-shadow 0.7s ease;
  }
  .howb-dot[data-on="true"] {
    background: var(--color-brand);
    border-color: var(--color-brand);
  }
  .howb-dot[data-head="true"] {
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-brand) 18%, transparent);
  }
  .howb-col__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: 0;
    color: var(--color-ink);
  }
  .howb-col__text {
    margin: 10px 0 0;
    color: var(--color-muted);
    font-size: 14px;
    line-height: 1.5;
  }

  /* узкие экраны — вертикальный таймлайн: линия слева, этапы стопкой */
  @media (max-width: 860px) {
    .howb-line {
      top: 0;
      bottom: 0;
      left: 6px;
      right: auto;
      width: 1px;
      height: auto;
    }
    .howb-line-fill {
      top: 0;
      left: 5px;
      width: 2px;
      height: 0;
    }
    .howb-cols {
      grid-template-columns: 1fr;
      grid-auto-flow: row;
      gap: 28px;
    }
    .howb-col {
      padding-top: 0;
      padding-left: 30px;
    }
    .howb-dot {
      top: 1px;
      left: 0;
    }
  }
</style>

<script>
  // Первая точка светится; от неё линия ползёт к следующей с ПОСТОЯННОЙ
  // скоростью; как только линия дошла — точка синеет и становится головой,
  // линия ползёт дальше. В конце пауза, плавное гашение, и цикл повторяется.
  const tl = document.querySelector<HTMLElement>('.howb-timeline');
  if (tl) {
    const track = tl.querySelector<HTMLElement>('.howb-track');
    const fill = tl.querySelector<HTMLElement>('.howb-line-fill');
    const dots = Array.from(tl.querySelectorAll<HTMLElement>('.howb-dot'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (track && fill && dots.length) {
      const vertQ = window.matchMedia('(max-width: 860px)');
      let vertical = vertQ.matches; // на узких экранах таймлайн вертикальный

      // координата центра точки вдоль оси таймлайна, относительно трека
      const center = (d: HTMLElement, base: number) => {
        const r = d.getBoundingClientRect();
        return (vertical ? r.top + r.height / 2 : r.left + r.width / 2) - base;
      };

      // заливка растёт вдоль оси (width/height), поперёк задаётся в CSS;
      // противоположную ось обнуляем, чтобы стили не залипали при смене ориентации
      const applyFill = (start: number, extent: number) => {
        if (vertical) {
          fill.style.left = '';
          fill.style.width = '';
          fill.style.top = `${start}px`;
          fill.style.height = `${extent}px`;
        } else {
          fill.style.top = '';
          fill.style.height = '';
          fill.style.left = `${start}px`;
          fill.style.width = `${extent}px`;
        }
      };

      let x0 = 0;
      let offs: number[] = []; // расстояние от центра dot0 до каждой точки
      let dotsW = 0; // от первой до последней точки — задаёт скорость проезда
      let maxW = 0; // полная длина заливки — до дальнего края трека (с хвостом)
      const measure = () => {
        const tr = track.getBoundingClientRect();
        const base = vertical ? tr.top : tr.left;
        x0 = center(dots[0], base);
        offs = dots.map((d) => center(d, base) - x0);
        dotsW = offs[offs.length - 1];
        // хвост после последней точки тоже заливается (до края трека)
        maxW = (vertical ? track.clientHeight : track.clientWidth) - x0;
      };

      // залить точки до head включительно; head — светящаяся (текущая).
      // Перерисовываем только при смене head — не дёргаем CSS-transition точек.
      let lastHead = -2;
      const lit = (head: number) => {
        if (head === lastHead) return;
        lastHead = head;
        dots.forEach((d, i) => {
          d.dataset.on = i <= head ? 'true' : 'false';
          d.dataset.head = i === head ? 'true' : 'false';
        });
      };

      if (reduce) {
        const paint = () => {
          measure();
          lit(dots.length - 1); // статично: всё пройдено
          applyFill(x0, maxW);
        };
        paint();
        vertQ.addEventListener('change', (ev) => {
          vertical = ev.matches;
          paint();
        });
        window.addEventListener('resize', paint);
      } else {
        // Единый таймер — requestAnimationFrame. Ширину заливки считаем от
        // прошедшего времени (постоянная скорость), точку зажигаем ровно
        // когда заливка прошла её центр. Один источник времени → нет
        // рассинхрона «точка раньше линии» и рывков от throttling таймеров.
        fill.style.transition = 'none';

        const SEG = 820; // мс на участок (равные участки → постоянная скорость)
        const START_HOLD = 600; // свечение первой точки перед стартом
        const END_HOLD = 1700; // пауза на завершённом таймлайне
        const FADE = 520; // плавное гашение перед перезапуском

        let phase: 'start' | 'crawl' | 'end' | 'fade' = 'start';
        let t0 = -1;

        const begin = () => {
          measure();
          applyFill(x0, 0);
          fill.style.opacity = '1';
          lastHead = -2;
          lit(0); // первая точка светится
        };

        const frame = (ts: number) => {
          if (t0 < 0) {
            t0 = ts;
            begin();
          }
          const e = ts - t0;
          const crawlMs = SEG * (dots.length - 1);

          if (phase === 'start') {
            if (e >= START_HOLD) {
              phase = 'crawl';
              t0 = ts;
            }
          } else if (phase === 'crawl') {
            const w = Math.min(maxW, (dotsW / crawlMs) * e);
            applyFill(x0, w);
            let head = 0;
            for (let k = 0; k < offs.length; k++) if (w + 0.5 >= offs[k]) head = k;
            lit(head); // точка синеет в момент, когда линия дошла
            if (w >= maxW) {
              phase = 'end';
              t0 = ts;
            }
          } else if (phase === 'end') {
            applyFill(x0, maxW);
            lit(dots.length - 1);
            if (e >= END_HOLD) {
              phase = 'fade';
              t0 = ts;
              lit(-1); // точки гаснут своим CSS-transition
            }
          } else {
            fill.style.opacity = `${Math.max(0, 1 - e / FADE)}`;
            if (e >= FADE) {
              phase = 'start';
              t0 = ts;
              begin();
            }
          }
          requestAnimationFrame(frame);
        };

        requestAnimationFrame(frame);

        // геометрия в px зависит от размеров — пересчитать при ресайзе
        let rt = 0;
        window.addEventListener('resize', () => {
          window.clearTimeout(rt);
          rt = window.setTimeout(measure, 150);
        });
        // смена ориентации (узкий↔широкий) — перезапустить проезд с нуля
        vertQ.addEventListener('change', (ev) => {
          vertical = ev.matches;
          t0 = -1;
        });
      }
    }
  }
</script>
