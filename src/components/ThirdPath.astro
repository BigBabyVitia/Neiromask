---
import { t } from '../copy';
import SilkBg from './SilkBg.astro';

// Блок 1 — что есть на рынке сейчас (два компромиссных пути).
const market = [
  {
    title: 'Незащищённый доступ в облаке',
    desc: 'Быстрый старт и доступ к сильным моделям — но исходные ФИО, паспорта и реквизиты уходят во внешнюю модель без единого аудита и правил.',
  },
  {
    title: 'Полностью закрытый контур',
    desc: 'Данные не покидают компанию и контроль максимальный — но инфраструктура дорогая, а путь до production долгий.',
  },
];

// Блок 2 — что предлагаем мы.
const offer = [
  {
    title: 'Маскируем ПДн до выхода в API',
    desc: 'ФИО, телефоны, паспорта и реквизиты заменяются плейсхолдерами до отправки во внешнюю модель.',
  },
  {
    title: 'Восстанавливаем ответ внутри контура',
    desc: 'Реальные значения подставляются обратно в контуре Нейроключа — пользователь видит готовый результат, а не плейсхолдеры.',
  },
  {
    title: 'Единый аудит и правила обработки',
    desc: 'Кто отправил, какие сущности найдены и какое действие применено — всё фиксируется и доступно для аудита.',
  },
];
---

{/* ── Блок 1: что есть на рынке (шашечка: текст справа / визуал слева) ── */}
<section class="section aj-small" id="tp-market">
  <div class="needs-split rev">
    <div class="needs-col">
      <div class="needs-head">
        <h2 class="needs-title">Что есть на рынке сейчас</h2>
      </div>

      <ul class="needs-list">
        {
          market.map((p, i) => (
            <li class={`needs-item${i === 0 ? ' is-active' : ''}`} data-needs={i}>
              <span class="needs-progress" aria-hidden="true" />
              <strong class="needs-item__title">{p.title}</strong>
              <div class="needs-item__panel">
                <p class="needs-item__desc">{p.desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="needs-visual silk-grad">
      <SilkBg />
      {/* Две рыночные крайности: облако с риском или дорогой on-prem. */}
      <div class="tp-diagram tp-diagram--options" aria-hidden="true">
        <div class="nm-node nm-node--warn">
          <div class="nm-node-title">Облако как есть</div>
          <div class="nm-node-desc">ПДн уходят наружу</div>
        </div>
        <span class="tp-or">или</span>
        <div class="nm-node">
          <div class="nm-node-title">Полный on-prem</div>
          <div class="nm-node-desc">дорого и долго</div>
        </div>
      </div>
    </div>
  </div>
</section>

{/* ── Блок 2: что предлагаем мы (текст слева / визуал справа) ── */}
<section class="section aj-small" id="tp-offer">
  <div class="needs-split">
    <div class="needs-col">
      <div class="needs-head">
        <h2 class="needs-title" data-copy="tp.h2">Что предлагаем мы</h2>
      </div>

      <ul class="needs-list">
        {
          offer.map((p, i) => (
            <li class={`needs-item${i === 0 ? ' is-active' : ''}`} data-needs={i}>
              <span class="needs-progress" aria-hidden="true" />
              <strong class="needs-item__title">{p.title}</strong>
              <div class="needs-item__panel">
                <p class="needs-item__desc">{p.desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="needs-visual silk-grad">
      <SilkBg />
      {/* Наш поток: приложение → НейроМаск → облако (восстановление обратно). */}
      <div class="tp-diagram" aria-hidden="true">
        <div class="nm-infrastructure">
          <span class="nm-infra-label">Ваша инфраструктура</span>
          <div class="nm-node nm-app">
            <div class="nm-node-title">Бизнес-приложение</div>
            <div class="nm-node-desc">или внутренний портал</div>
          </div>
          <div class="nm-flow">
            <div class="nm-arrow nm-down" />
            <div class="nm-arrow nm-up" />
          </div>
          <div class="nm-node nm-node-center">
            <div class="nm-node-title">НейроМаск</div>
            <div class="nm-node-desc">Анонимизация и контроль</div>
          </div>
        </div>

        <div class="nm-flow">
          <div class="nm-arrow nm-down" />
          <div class="nm-arrow nm-up" />
        </div>

        <div class="nm-node nm-cloud">
          <div class="nm-node-title">Облачные LLM</div>
          <div class="nm-node-desc">OpenAI, Anthropic, Yandex…</div>
        </div>
      </div>
    </div>
  </div>

  <div class="aj-note">
    <span class="aj-key s">S</span>
    <span>
      <strong>Снятие барьера выбора:</strong> третий путь между небезопасным облаком и
      тяжёлым on-prem — сила внешних моделей без передачи исходных ПДн.
    </span>
  </div>
</section>

<style>
  /* (bottom-pin списка вынесен в global .needs-list — общий для Needs и обеих шашек) */

  /* зеркальный вариант эталонной структуры (шашечка): текст справа, визуал слева */
  .needs-split.rev .needs-col {
    order: 2;
  }
  .needs-split.rev .needs-visual {
    order: 1;
  }
  @media (max-width: 860px) {
    .needs-split.rev .needs-col {
      order: 0;
    }
  }

  /* Визуал поверх силк-шейдера. Переиспользуем язык диаграммы (nm-*). */
  .tp-diagram {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 6%, 48px);
  }
  .tp-diagram--options {
    gap: 14px;
  }
  .tp-or {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    padding: 3px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .nm-infrastructure {
    position: relative;
    width: min(300px, 86%);
    border: 1px dashed color-mix(in srgb, var(--color-line) 70%, var(--color-muted));
    border-radius: 16px;
    padding: 22px 18px 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .nm-infra-label {
    position: absolute;
    top: -9px;
    background: var(--color-surface);
    padding: 0 10px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }
  .nm-node {
    width: min(300px, 86%);
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    border-radius: 12px;
    padding: 13px 12px;
    text-align: center;
    box-shadow: 0 6px 16px rgba(22, 38, 78, 0.08);
  }
  .nm-infrastructure .nm-node {
    width: 100%;
  }
  .nm-app {
    background: color-mix(in srgb, var(--color-bg) 80%, var(--color-surface));
  }
  .nm-node--warn {
    border-color: color-mix(in srgb, var(--color-warn) 45%, var(--color-line));
    background: color-mix(in srgb, var(--color-warn) 8%, var(--color-surface));
  }
  .nm-node--warn .nm-node-title {
    color: var(--color-warn);
  }
  .nm-node-center {
    border: none;
    color: #fff;
    background: linear-gradient(135deg, #2a52d6 0%, #163fb8 100%);
    box-shadow: 0 14px 30px rgba(22, 63, 184, 0.28);
    overflow: hidden;
  }
  .nm-node-center .nm-node-title,
  .nm-node-center .nm-node-desc {
    color: #fff;
    position: relative;
    z-index: 2;
  }
  .nm-node-title {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 3px;
    color: var(--color-ink);
  }
  .nm-node-desc {
    font-size: 12px;
    color: var(--color-muted);
  }

  /* анимированные стрелки потока */
  .nm-flow {
    display: flex;
    gap: 12px;
    height: 24px;
    margin: 7px 0;
  }
  .nm-arrow {
    width: 4px;
    height: 100%;
    position: relative;
    background-color: color-mix(in srgb, var(--color-line) 80%, transparent);
    border-radius: 2px;
    overflow: hidden;
  }
  .nm-arrow::before {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 13px;
    background: var(--color-brand-strong);
    filter: blur(1px);
  }
  .nm-down::before {
    top: 0;
    animation: tpDown 1.5s infinite linear;
  }
  .nm-up::before {
    bottom: 0;
    animation: tpUp 1.5s infinite linear;
  }
  @keyframes tpDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(220%); }
  }
  @keyframes tpUp {
    0% { transform: translateY(220%); }
    100% { transform: translateY(-100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .nm-arrow::before { animation: none; }
  }
</style>

<script>
  // Аккордеон трёх путей — тот же паттерн, что в Needs: открыт всегда один
  // пункт, авто-переключение по таймеру (.needs-progress), клик перебивает.
  // Инициализируем для обоих блоков.
  const initAccordion = (root: HTMLElement) => {
    const items = Array.from(root.querySelectorAll<HTMLElement>('.needs-item'));
    const bars = items.map((item) => item.querySelector<HTMLElement>('.needs-progress'));

    const activate = (idx: number) => {
      items.forEach((item, i) => item.classList.toggle('is-active', i === idx));
    };

    bars.forEach((bar, i) => {
      bar?.addEventListener('animationend', () => {
        if (items[i].classList.contains('is-active')) activate((i + 1) % items.length);
      });
    });

    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        if (item.classList.contains('is-active')) {
          const bar = bars[i];
          if (bar) {
            bar.style.animation = 'none';
            void bar.offsetWidth;
            bar.style.animation = '';
          }
        } else {
          activate(i);
        }
      });
    });
  };

  ['tp-market', 'tp-offer'].forEach((id) => {
    const root = document.getElementById(id);
    if (root) initAccordion(root);
  });
</script>
