---
import MobileNav from './islands/MobileNav.tsx';

const links = [
  { href: '#problem', label: 'Проблема' },
  { href: '#fit', label: 'Где работает' },
  { href: '#how', label: 'Как работает' },
  { href: '#example', label: 'Пример' },
  { href: '#pilot', label: 'Цена' },
];
---

<header class="nav-header sticky top-0 z-30" id="site-header" data-scrolled="false" data-mode="full">
  <div class="nav-bar">
    <div class="nav-side nav-side--left">
      <MobileNav links={links} client:load />
      <a class="nav-logo" href="#top">
        <span class="logo-mark" aria-hidden="true">
          <img class="logo-shield" src="/logo-shield.svg" alt="" width="36" height="36" />
        </span>
        <span class="nav-logo-name">НейроМаск</span>
      </a>
    </div>

    <nav class="nav-center hidden md:flex" aria-label="Разделы">
      {links.map((l) => <a class="nav-link" href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-side nav-side--right">
      <a
        class="nav-burger nav-burger--primary grid h-11 w-11 place-items-center md:hidden"
        href="#request"
        aria-label="Обсудить"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
        </svg>
      </a>
      <a class="nav-cta hidden md:inline-flex" href="#request">Разобрать сценарий</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    header?.setAttribute('data-scrolled', String(window.scrollY > 8));
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
